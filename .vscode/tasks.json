{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build-frontend-production",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"build"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "deploy-firebase-hosting",
			"type": "shell",
			"command": "npx",
			"args": [
				"firebase",
				"deploy",
				"--only",
				"hosting",
				"--project",
				"pandastoreupdate"
			],
			"isBackground": false,
			"group": "build"
		}
	]
}